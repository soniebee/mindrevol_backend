<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="025-create-box-invitations" author="mindrevol">
        <createTable tableName="box_invitations">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            
            <column name="box_id" type="VARCHAR(36)">
                <constraints nullable="false" foreignKeyName="fk_bi_box" referencedTableName="boxes" referencedColumnNames="id" deleteCascade="true"/>
            </column>
            
            <column name="inviter_id" type="VARCHAR(36)">
                <constraints nullable="false" foreignKeyName="fk_bi_inviter" referencedTableName="users" referencedColumnNames="id" deleteCascade="true"/>
            </column>
            
            <column name="invitee_id" type="VARCHAR(36)">
                <constraints nullable="false" foreignKeyName="fk_bi_invitee" referencedTableName="users" referencedColumnNames="id" deleteCascade="true"/>
            </column>
            
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>

        <sql dbms="postgresql">
            CREATE UNIQUE INDEX uk_bi_spam ON box_invitations (box_id, invitee_id) WHERE status = 'PENDING';
        </sql>
        
        <rollback>
            <sql>DROP INDEX IF EXISTS uk_bi_spam;</sql>
            <dropTable tableName="box_invitations"/>
        </rollback>
    </changeSet>

</databaseChangeLog>